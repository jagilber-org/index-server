{
	"servers": {
		"Index-leader": {
			"type": "stdio",
			"command": "node",
			"args": [
				"<root>\\\\index-server-dev\\dist\\server\\index-server.js"
			],
			"env": {
				"INDEX_SERVER_MUTATION": "true",
				"INDEX_SERVER_BOOTSTRAP_AUTOCONFIRM": "true",
				"INDEX_SERVER_LOG_LEVEL": "info",
				"INDEX_SERVER_DASHBOARD": "true",
				"INDEX_SERVER_DASHBOARD_PORT": "9500",
				"INDEX_SERVER_DASHBOARD_HOST": "127.0.0.1",
				"INDEX_SERVER_AUDIT_LOG": "true",
				"INDEX_SERVER_DIR": "<root>\\\\index-server-dev\\instructions",
				"INDEX_SERVER_AUTO_SEED": "true",
				"INDEX_SERVER_FLAG_TOOLS_EXTENDED": "1",
				"INDEX_SERVER_FLAG_TOOLS_ADMIN": "1",
				"INDEX_SERVER_MODE": "leader",
				"INDEX_SERVER_LEADER_PORT": "9090",
				"INDEX_SERVER_HEARTBEAT_MS": "5000",
				"INDEX_SERVER_STALE_THRESHOLD_MS": "15000"
			}
		},
		"Index-thin": {
			"type": "stdio",
			"command": "node",
			"args": [
				"<root>\\\\index-server-dev\\dist\\server\\thin-client.js"
			],
			"env": {
				"INDEX_SERVER_STATE_DIR": "<root>\\\\index-server-dev\\data\\state"
			}
		}
	},
	"inputs": []
}
