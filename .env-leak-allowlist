# ============================================================================
# .env-leak-allowlist — values from .env that are intentionally referenced in
# tracked repository files (docs, examples, instructions). Each entry is an
# exact-match exception for the dotenv-derived env-leak detector in
# scripts/pre-commit.{ps1,mjs}.
#
# Format:
#   literal:<exact value>
#
# Lines beginning with `#` are comments. Whitespace-only lines are ignored.
#
# Add a new entry only when:
#   1. The .env value is a *generic recommendation*, not a per-developer secret.
#   2. The value already appears in tracked files for documentation purposes
#      (e.g. quickstart guides, deployment docs, CodeQL setup notes).
#   3. Removing the value from tracked files would harm reader/onboarding UX.
#
# Anything user-specific (usernames, org names you don't want public, real
# deployment paths) must NOT be allowlisted — generalize the tracked file
# instead.
# ============================================================================

# Recommended local deployment roots (docs/deployment.md, scripts/deploy-local.ps1).
literal:C:\mcp\index-server
literal:C:\mcp\index-server-dev

# Recommended off-repo CodeQL paths (docs: scripts/run-codeql-pre-push.ps1
# header, .env.example CodeQL section, .instructions/local CodeQL notes).
literal:C:\codeql\dbs\index-server-js
literal:C:\codeql\logs\index-server-js
literal:C:\codeql\sarif\index-server-results.sarif

# Public-mirror clean-room path. This is the documented default in
# scripts/Invoke-ReleaseWorkflow.ps1 (-CleanRoomPath) and is required by the
# release workflow. The org segment `jagilber-org` is a public GitHub org;
# this is intentional repository-public surface, not contributor-personal.
literal:C:\github\jagilber-org\index-server

# Generic Docker container path for the runtime instruction store. This is
# the documented mount target in docker-compose.yml and docs/docker_deployment.md
# (referenced as INDEX_SERVER_DIR=/app/instructions inside the container).
# It is a fixed, public, container-internal path — not contributor-specific.
literal:/app/instructions
