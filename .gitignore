# ===================================================================
# RUNTIME ARTIFACTS - NEVER COMMIT
# ===================================================================
# These directories contain runtime-generated data, test artifacts,
# and temporary files that MUST NEVER be committed to the repository.

# Temporary directories and scratch space (ALL test artifacts)
tmp/
tmp/**
tmp/**/*.tmp

# Runtime data and state directories
data/
data/**
!data/.gitkeep
memory/
memory/**
!memory/.gitkeep
# Keep the checked-in spec constitution while leaving other memory outputs ignored.
!/.specify/memory/
/.specify/memory/*
!/.specify/memory/constitution.md
metrics/
metrics/**
!metrics/.gitkeep

# Test run sentinel / status markers (ALL test markers)
.test-run-complete.*.marker
.test-run-complete.*
.test-run-status.json
.test-run-complete.latest
.baseline.sentinel

# MCP and VS Code workspace configurations
# Ignore local MCP workspace config (contains machine-specific paths)
.vscode/mcp.json
.vscode/mcp-dev.json
.vscode/mcp.json.generated

# Local environment overrides and configurations
*.local.json
mcp.local.json

# Platform-specific files
# Mac metadata
.AppleDouble

# Security and secrets
# Prevent accidental commit of potential secrets snapshots
secrets/
snapshots/*
!snapshots/.gitkeep

# Generated documentation artifacts
docs/**/*.pdf
docs/**/*.docx
docs/scan-reconciliation-*.md

# Test health files and temporary diagnostics
test-health*.json
health_response.json

# ===================================================================
# TEST-GENERATED INSTRUCTION ARTIFACTS - DO NOT COMMIT
# ===================================================================
# These patterns match files created by test suites that write to
# instructions/ directory during test execution. Tests MUST clean up
# these files in afterAll/afterEach hooks. This .gitignore is a safety
# net to prevent accidental commits if cleanup fails.
#
# Patterns and their source tests:
# - smoke-*.json: createReadSmoke.spec.ts
# - mw-disabled-*.json: manifestEdgeCases.spec.ts (write disabled test)
# - mw-repair-*.json: manifestEdgeCases.spec.ts (repair test)
# - vis-*.json: addVisibilityInvariant.spec.ts
# - synthetic-*.json: Dashboard synthetic load tests (ApiRoutes.ts)
# - unit_p0_materialize_*.json: IndexContext.usage.unit.spec.ts
# - unit_usageMonotonic_*.json: IndexContext.usage.unit.spec.ts
#
# CI enforcement: validate-no-test-artifacts.mjs checks for these
# patterns and fails the build if any exist, ensuring cleanup works.
# ===================================================================
instructions/smoke-*.json
instructions/mw-disabled-*.json
instructions/mw-repair-*.json
instructions/vis-*.json
instructions/synthetic-*.json
instructions/unit_p0_materialize_*.json
instructions/unit_usageMonotonic_*.json

# Backup and archive files
*.bak
*.backup
*.old
*.orig
*_backup_*/
backup-*.zip

# Private development workspace (user-specific files)
.private/

CLEANUP-RUNTIME-ARTIFACTS.txt
ACTIVATION_TOOLS_IMPLEMENTATION_SUMMARY.md
NVIDIA Corporation/
PLAN.md
.dist.keep

# Runtime data directories (keep dirs via .gitkeep, ignore contents)
governance/
!governance/.gitkeep
!backups/.gitkeep
!feedback/.gitkeep
!tmp/.gitkeep
!snapshots/.gitkeep

