# ============================================================================
# index-server repo-specific environment overrides
# ----------------------------------------------------------------------------
# Copy this file to `.env` and edit the values for your local clone.
#
#   pwsh> Copy-Item .env.example .env
#
# `.env` is gitignored, blocked by pre-commit, and excluded from cleanroom
# copies (see scripts/pre-commit.ps1 and scripts/New-CleanRoomCopy.ps1).
# Safe place for machine-specific paths and the admin API key.
#
# Loaded by `scripts/Load-RepoEnv.ps1` (sourced by Invoke-ReleaseWorkflow.ps1
# and any script that opts in). Manual usage:
#
#   pwsh> . scripts/Load-RepoEnv.ps1
#
# Format:
#   - One KEY=VALUE per line.
#   - `#` starts a comment (full-line only).
#   - No quoting needed; values are taken verbatim up to the line end.
#   - Existing $env:KEY values are NOT overwritten (process env wins).
# ============================================================================

# --- Release workflow (scripts/Invoke-ReleaseWorkflow.ps1) ------------------

# Absolute path of the clean-room sibling clone (Phase 3 target).
# This is the public-mirror clone that Publish-ToMirror.ps1 pushes from.
# Replace `<your-org>` and the path to match your machine; this is intentionally
# left as a placeholder so a copy/paste from a contributor's local .env doesn't
# leak the contributor's directory layout into the public template.
# CLEANROOM_PATH=C:\path\to\public-mirror-clone

# Public mirror URL. Defaults to .publish-config.json -> sanctionedRemotes[0].
# Set here only to override for a personal fork.
# REMOTE_URL=https://github.com/jagilber-org/index-server.git

# Release tag override. Default is `v<package.json version>`.
# RELEASE_TAG=v1.27.0

# --- Local deploy (scripts/deploy-local.ps1) --------------------------------

# Production install root.
DEPLOY_PROD_PATH=C:\mcp\index-server

# Development install root.
DEPLOY_DEV_PATH=C:\mcp\index-server-dev

# --- Admin client (scripts/index-server-client.ps1) -------------------------

# Base URL of the local server you want client scripts to hit.
# INDEX_SERVER_URL=http://localhost:8787

# Admin API key (SENSITIVE). Required for mutating admin endpoints.
# INDEX_SERVER_ADMIN_API_KEY=

# --- Runtime toggles (scripts/deploy-local.ps1, server runtime) -------------

# 1 = enable dashboard. Empty/0 = disabled.
# INDEX_SERVER_DASHBOARD=1

# 1 = verbose server logging.
# INDEX_SERVER_VERBOSE_LOGGING=

# 1 = mutation tools enabled at runtime.
# INDEX_SERVER_MUTATION=

# --- Build / test tuning ----------------------------------------------------

# 1 = ignore stale build locks (scripts/build.ps1).
# ALLOW_STALE_BUILD_LOCK=

# 1 = skip the pretest build (scripts/pretest-build-or-skip.ps1).
# SKIP_PRETEST_BUILD=

# 1 = force a rebuild even if SKIP_PRETEST_BUILD is set.
# INDEX_SERVER_FORCE_REBUILD=

# Pre-push slow-test suite timeout in seconds (default 120).
# PRE_PUSH_TIMEOUT_SEC=120

# 1 = allow pre-push to continue past failing slow tests.
# ALLOW_FAILING_SLOW=

# --- Coverage gates (scripts/check-coverage.mjs) ----------------------------

# Hard minimum coverage percent (default 50).
# INDEX_SERVER_COVERAGE_HARD_MIN=50

# Target coverage percent (default = hard min).
# INDEX_SERVER_COVERAGE_TARGET=

# --- CodeQL local pre-push gate (scripts/run-codeql-pre-push.ps1) -----------
#
# Keep CodeQL artifacts OUTSIDE the repo and OFF any synced path
# (Windows: %LOCALAPPDATA% may be redirected into OneDrive via Known Folder
# Move, which causes mass file hydration and apparent hangs). Use C:\codeql.

# Absolute path for the CodeQL database (multi-GB build artifact).
# Default if unset: .codeql/db-main (in-repo, not recommended).
# CODEQL_DB_PATH=C:\codeql\dbs\index-server-js

# Absolute path for CodeQL driver logs (per-run files).
# Default if unset: .codeql/logs
# CODEQL_LOG_DIR=C:\codeql\logs\index-server-js

# Output SARIF path. Default if unset: .codeql/results-prepush.sarif
# CODEQL_OUTPUT_PATH=C:\codeql\sarif\index-server-results.sarif

# Language id passed to `codeql database create` (must match GHAS workflow).
# Default if unset: javascript
# CODEQL_LANGUAGE=javascript

# Extractor thread count. 0 = use all cores. Default if unset: 0
# CODEQL_THREADS=0

# Extractor RAM cap in MB. Default if unset: 8192
# CODEQL_RAM=8192

# 1 = skip the local CodeQL gate (audit-logged). NOT RECOMMENDED.
# SKIP_CODEQL=
