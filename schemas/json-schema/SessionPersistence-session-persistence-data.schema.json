{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/SessionPersistenceData",
  "definitions": {
    "SessionPersistenceData": {
      "type": "object",
      "properties": {
        "adminSessions": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/PersistedAdminSession"
          }
        },
        "webSocketConnections": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/PersistedWebSocketConnection"
          }
        },
        "sessionHistory": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/PersistedSessionHistoryEntry"
          }
        },
        "metadata": {
          "$ref": "#/definitions/SessionPersistenceMetadata"
        }
      },
      "required": [
        "adminSessions",
        "webSocketConnections",
        "sessionHistory",
        "metadata"
      ],
      "additionalProperties": false
    },
    "PersistedAdminSession": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "userId": {
          "type": "string"
        },
        "startTime": {
          "type": "string"
        },
        "lastActivity": {
          "type": "string"
        },
        "ipAddress": {
          "type": "string"
        },
        "userAgent": {
          "type": "string"
        },
        "permissions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "persistedAt": {
          "type": "string"
        },
        "version": {
          "type": "number"
        }
      },
      "required": [
        "id",
        "userId",
        "startTime",
        "lastActivity",
        "ipAddress",
        "userAgent",
        "permissions",
        "persistedAt",
        "version"
      ],
      "additionalProperties": false,
      "description": "Session Persistence Schema Design\n\nPersistent storage design for admin sessions, websocket connections, and session history with deduplication, atomic writes, and backup integration."
    },
    "PersistedWebSocketConnection": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "clientId": {
          "type": "string"
        },
        "connectedAt": {
          "type": "string"
        },
        "lastActivity": {
          "type": "string"
        },
        "ipAddress": {
          "type": "string"
        },
        "userAgent": {
          "type": "string"
        },
        "isActive": {
          "type": "boolean"
        },
        "disconnectedAt": {
          "type": "string"
        },
        "disconnectReason": {
          "type": "string"
        },
        "persistedAt": {
          "type": "string"
        },
        "version": {
          "type": "number"
        }
      },
      "required": [
        "id",
        "clientId",
        "connectedAt",
        "lastActivity",
        "isActive",
        "persistedAt",
        "version"
      ],
      "additionalProperties": false
    },
    "PersistedSessionHistoryEntry": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "userId": {
          "type": "string"
        },
        "startTime": {
          "type": "string"
        },
        "endTime": {
          "type": "string"
        },
        "ipAddress": {
          "type": "string"
        },
        "userAgent": {
          "type": "string"
        },
        "terminated": {
          "type": "boolean"
        },
        "terminationReason": {
          "type": "string"
        },
        "persistedAt": {
          "type": "string"
        },
        "version": {
          "type": "number"
        }
      },
      "required": [
        "id",
        "userId",
        "startTime",
        "ipAddress",
        "userAgent",
        "persistedAt",
        "version"
      ],
      "additionalProperties": false
    },
    "SessionPersistenceMetadata": {
      "type": "object",
      "properties": {
        "lastPersisted": {
          "type": "string"
        },
        "version": {
          "type": "number"
        },
        "totalSessions": {
          "type": "number"
        },
        "totalConnections": {
          "type": "number"
        },
        "totalHistoryEntries": {
          "type": "number"
        },
        "checksums": {
          "type": "object",
          "properties": {
            "sessions": {
              "type": "string"
            },
            "connections": {
              "type": "string"
            },
            "history": {
              "type": "string"
            }
          },
          "required": [
            "sessions",
            "connections",
            "history"
          ],
          "additionalProperties": false
        }
      },
      "required": [
        "lastPersisted",
        "version",
        "totalSessions",
        "totalConnections",
        "totalHistoryEntries",
        "checksums"
      ],
      "additionalProperties": false
    }
  }
}
